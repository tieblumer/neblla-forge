# neblla-forge (the machinery). The product it builds lives in project/ and is its
# OWN git repo (github.com/tieblumer/neblla.git) — the forge must never track it.
project/

node_modules
*.log

# forge UI (npm run forge) — las conversaciones son demasiado efímeras para git;
# solo generarían ruido. Cada sprint arranca limpio. Viven solo en el working tree.
forge/sprint/chats/
forge/sprint/cycle.json
# pantallazos pegados en el chat (working-tree only, como las conversaciones).
pantallazos/
# contador de tokens (scripts/forge-token-log.js): registro de gasto por spawn,
# artefacto de runtime que se regenera solo. Nunca a git.
forge/sprint/token-log.jsonl

# forge machinery transient artifacts — never committed.
scripts/_work/
.wt/
.bitacora-*.txt
.forge-browser/

# sprint director (scripts/sprint.js) transients
forge/backbone/sprints/.verdict.json
forge/backbone/sprints/.hotfix-needed.json
forge/backbone/sprints/.coherence-advisory.md
forge/backbone/sprints/*.state.json
forge/backbone/sprints/*.state.json.tmp-*

# sandbox heart (scripts/heart.js) transients — the NOTES live in the working tree
# only (gitignored), seeded into worktrees by the heart, never via git.
forge/backbone/sandbox/.heart.json
forge/backbone/sandbox/.heart.log
forge/backbone/sandbox/.drain-requested
forge/backbone/sandbox/.sandbox-drained
forge/backbone/sandbox/.worktree-commands.json
forge/backbone/sandbox/**/*.tmp-*
forge/backbone/sandbox/.demo/
forge/backbone/sandbox/notas/

# product secrets backup — never track
neblla-env-backup/
